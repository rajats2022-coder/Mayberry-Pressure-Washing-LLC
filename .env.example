# Copy this to .env.local and fill in one source.
# Do not commit .env.local.

# Preferred: full owned-location review history from Google Business Profile.
GOOGLE_BUSINESS_PROFILE_MANAGER_EMAIL=s4aiagency@gmail.com
GOOGLE_BUSINESS_PROFILE_ACCOUNT_ID=
GOOGLE_BUSINESS_PROFILE_LOCATION_ID=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# Optional short-lived override for testing only.
GOOGLE_BUSINESS_PROFILE_ACCESS_TOKEN=

# Fallback: count plus limited latest/relevant review data from Places API.
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=ChIJH1R4E00DQg4R_BKHMqJrDzc

# Review reply automation through OpenRouter.
OPENROUTER_API_KEY=
MAYBERRY_REVIEW_REPLY_MODEL=openai/gpt-4.1-nano
MAYBERRY_REVIEW_REPLY_LIMIT=20
MAYBERRY_REVIEW_REPLY_DRY_RUN=0
MAYBERRY_CONTACT_URL=https://www.mayberrypw.com/contact
MAYBERRY_PHOTO_DESCRIPTION=Finished a nice cleaning today, satisfied customer.
MAYBERRY_PHOTO_CATEGORY=ADDITIONAL
MAYBERRY_PHOTO_SOURCE_BASE_URL=https://www.mayberrypw.com

# Optional: push updated website files after a successful change.
MAYBERRY_REVIEWS_AUTO_PUSH=0
